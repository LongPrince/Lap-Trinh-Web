@{
    ViewData["Title"] = "Loại hàng";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />

<section class="content-header mb-3">
    <div class="container-fluid d-flex justify-content-between align-items-center">
        <h3 class="fw-bold">
            <i class="fa-solid fa-layer-group me-2"></i> Loại hàng
        </h3>
        <a href="/Category/Create" class="btn btn-primary">
            <i class="fa-solid fa-plus"></i> Thêm loại
        </a>
    </div>
</section>

<div class="container-fluid">
    <div class="card p-3">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Tên loại</th>
                    <th>Mô tả</th>
                    <th class="text-center" style="width:150px">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>Điện thoại</td>
                    <td>Thiết bị di động</td>
                    <td class="text-center">
                        <a href="/Category/Edit/1" class="btn btn-sm btn-outline-warning">
                            <i class="fa-solid fa-pen"></i>
                        </a>
                        <a href="/Category/Delete/1"
                           onclick="return confirm('Xóa loại này?')"
                           class="btn btn-sm btn-outline-danger">
                            <i class="fa-solid fa-trash"></i>
                        </a>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
