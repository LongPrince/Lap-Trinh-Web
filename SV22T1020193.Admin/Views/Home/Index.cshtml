@{
    ViewData["Title"] = "Dashboard";
}

<section class="content-header mb-4">
    <h3 class="fw-bold">
        <i class="fa-solid fa-gauge-high me-2"></i> Dashboard
    </h3>
    <p class="text-muted mb-0">Tổng quan hệ thống</p>
</section>

<!-- THỐNG KÊ NHANH -->
<div class="row">
    <div class="col-md-3 col-sm-6 mb-3">
        <div class="card shadow-sm border-0">
            <div class="card-body d-flex align-items-center">
                <div class="me-3 text-primary fs-2">
                    <i class="fa-solid fa-box"></i>
                </div>
                <div>
                    <h6 class="mb-0 text-muted">Sản phẩm</h6>
                    <h4 class="fw-bold mb-0">128</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3 col-sm-6 mb-3">
        <div class="card shadow-sm border-0">
            <div class="card-body d-flex align-items-center">
                <div class="me-3 text-success fs-2">
                    <i class="fa-solid fa-layer-group"></i>
                </div>
                <div>
                    <h6 class="mb-0 text-muted">Loại hàng</h6>
                    <h4 class="fw-bold mb-0">12</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3 col-sm-6 mb-3">
        <div class="card shadow-sm border-0">
            <div class="card-body d-flex align-items-center">
                <div class="me-3 text-warning fs-2">
                    <i class="fa-solid fa-users"></i>
                </div>
                <div>
                    <h6 class="mb-0 text-muted">Nhân viên</h6>
                    <h4 class="fw-bold mb-0">8</h4>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3 col-sm-6 mb-3">
        <div class="card shadow-sm border-0">
            <div class="card-body d-flex align-items-center">
                <div class="me-3 text-danger fs-2">
                    <i class="fa-solid fa-truck"></i>
                </div>
                <div>
                    <h6 class="mb-0 text-muted">Nhà cung cấp</h6>
                    <h4 class="fw-bold mb-0">5</h4>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- LỐI TẮT QUẢN LÝ -->
<div class="row mt-2">
    <div class="col-md-4 mb-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h5 class="fw-bold mb-3">
                    <i class="fa-solid fa-box me-2 text-primary"></i> Quản lý sản phẩm
                </h5>
                <p class="text-muted">
                    Thêm, sửa, xóa sản phẩm, hình ảnh và thuộc tính.
                </p>
                <a href="/Product" class="btn btn-outline-primary">
                    Đi tới <i class="fa-solid fa-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h5 class="fw-bold mb-3">
                    <i class="fa-solid fa-layer-group me-2 text-success"></i> Quản lý loại hàng
                </h5>
                <p class="text-muted">
                    Tổ chức và phân loại sản phẩm hiệu quả.
                </p>
                <a href="/Category" class="btn btn-outline-success">
                    Đi tới <i class="fa-solid fa-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h5 class="fw-bold mb-3">
                    <i class="fa-solid fa-users me-2 text-warning"></i> Quản lý nhân viên
                </h5>
                <p class="text-muted">
                    Phân quyền, quản lý tài khoản nhân viên.
                </p>
                <a href="/Employee" class="btn btn-outline-warning">
                    Đi tới <i class="fa-solid fa-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- CHÀO MỪNG -->
<div class="card mt-3 border-0 shadow-sm">
    <div class="card-body d-flex align-items-center">
        <div class="me-3 fs-2 text-primary">
            <i class="fa-solid fa-circle-info"></i>
        </div>
        <div>
            <h5 class="fw-bold mb-1">Chào mừng bạn đến với LiteCommerce Admin</h5>
            <p class="mb-0 text-muted">
                Hệ thống quản lý bán hàng – ASP.NET Core MVC
            </p>
        </div>
    </div>
</div>
