@model PagedResult<Product>
@{
    Layout = null;
}
<!-- Danh sách mặt hàng -->
@foreach (var item in Model.DataItems)
{
    <form method="post" class="border rounded p-2 mb-2">
        <strong>@item.ProductName</strong>

        <div class="row mt-2">
            <div class="col-4">
                <img src="~/images/products/demo.png"
                     class="img-fluid border" style="max-height:100px" />
            </div>
            <div class="col-8">
                <div class="row g-2">
                    <div class="col-7">
                        <label class="form-label mb-0">Giá</label>
                        <input class="form-control form-control-sm money-input"
                               value="@item.Price" />
                    </div>
                    <div class="col-5">
                        <label class="form-label mb-0">SL</label>
                        <input type="number"
                               min="1"
                               value="1"
                               class="form-control form-control-sm" />
                    </div>
                </div>

                <button class="btn btn-sm btn-primary mt-2 w-100">
                    <i class="bi bi-cart-plus"></i>
                    Thêm vào giỏ
                </button>
            </div>
        </div>
    </form>
}

@if (Model.PageCount > 1)
{
    <ul class="pagination pagination-sm justify-content-center mt-3 mb-0">
        <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
            <a class="page-link" href="javascript:;"
               onclick="paginationSearch(event, document.getElementById('formSearch'), @(Model.Page - 1))">
                <i class="bi bi-chevron-left"></i>
            </a>
        </li>

        @foreach (var p in Model.GetDisplayPages())
        {
            if (p.IsEllipsis)
            {
                <li class="page-item disabled"><span class="page-link">...</span></li>
            }
            else
            {
                <li class="page-item @(p.IsCurrent ? "active" : "")">
                    <a class="page-link" href="javascript:;"
                       onclick="paginationSearch(event, document.getElementById('formSearch'), @p.Page)">@p.Page</a>
                </li>
            }
        }

        <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
            <a class="page-link" href="javascript:;"
               onclick="paginationSearch(event, document.getElementById('formSearch'), @(Model.Page + 1))">
                <i class="bi bi-chevron-right"></i>
            </a>
        </li>
    </ul>
}