@{
    ViewData["Title"] = "Lập đơn hàng";
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Lập đơn hàng mới</h3>
    </div>

    <div class="card-body">

        <form asp-action="Create" method="post">

            <div class="row mb-3">
                <div class="col-md-6">
                    <label>Khách hàng</label>
                    <input type="text" class="form-control" placeholder="Tên khách hàng">
                </div>

                <div class="col-md-6">
                    <label>Ngày giao</label>
                    <input type="date" class="form-control">
                </div>
            </div>

            <hr />

            <h5>Thêm sản phẩm</h5>

            <div class="row mb-3">
                <div class="col-md-6">
                    <select class="form-select">
                        <option>-- Chọn sản phẩm --</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <input type="number" class="form-control" placeholder="Số lượng">
                </div>
                <div class="col-md-2">
                    <button type="button" class="btn btn-success">
                        <i class="fas fa-plus"></i> Thêm
                    </button>
                </div>
            </div>

            <hr />

            <button type="submit" class="btn btn-primary">
                <i class="fas fa-save"></i> Lưu đơn hàng
            </button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>

        </form>

    </div>
</div>