@{
    ViewData["Title"] = "Cập nhật nhân viên";
}

<section class="content-header mb-3">
    <h3 class="fw-bold">
        <i class="fa-solid fa-user-pen me-2"></i> Cập nhật nhân viên
    </h3>
</section>

<div class="container-fluid">
    <div class="card p-4">
        <form method="post">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Họ tên</label>
                    <input class="form-control" value="Nguyễn Văn A">
                </div>

                <div class="col-md-6">
                    <label class="form-label">Email</label>
                    <input class="form-control" value="a@gmail.com">
                </div>

                <div class="col-md-12">
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" checked>
                        <label class="form-check-label">Đang làm việc</label>
                    </div>
                </div>
            </div>

            <div class="text-end mt-4">
                <a href="/Employee" class="btn btn-light">Quay lại</a>
                <button class="btn btn-warning">
                    <i class="fa-solid fa-save"></i> Cập nhật
                </button>
            </div>
        </form>
    </div>
</div>
