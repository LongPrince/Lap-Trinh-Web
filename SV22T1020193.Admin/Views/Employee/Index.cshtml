@{
    ViewData["Title"] = "Danh sách nhân viên";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />

<style>
    .card {
        border-radius: 12px;
        border: none;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

    .table thead {
        background-color: #f8f9fa;
    }

    .table th {
        border-top: none;
        text-transform: uppercase;
        font-size: 12px;
        color: #6c757d;
    }

    .btn-action {
        width: 32px;
        height: 32px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        margin: 0 2px;
        transition: 0.3s;
    }

        .btn-action:hover {
            transform: translateY(-2px);
        }

    .badge-status {
        padding: 6px 12px;
        border-radius: 20px;
        font-weight: 500;
    }

    .avatar-sm {
        width: 35px;
        height: 35px;
        border-radius: 50%;
        background: #4e73df;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
    }
</style>

<section class="content-header mb-3">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-sm-6">
                <h3 class="fw-bold">
                    <i class="fa-solid fa-users-viewfinder me-2"></i> Nhân viên
                </h3>
            </div>
            <div class="col-sm-6 text-end">
                <a href="/Employee/Create" class="btn btn-primary shadow-sm">
                    <i class="fa-solid fa-plus-circle"></i> Thêm mới
                </a>
            </div>
        </div>
    </div>
</section>

<div class="container-fluid">
    <div class="card">
        <div class="card-header bg-white py-3">
            <form method="get" class="row g-2">
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0">
                            <i class="fa-solid fa-magnifying-glass text-muted"></i>
                        </span>
                        <input type="text" class="form-control border-start-0 bg-light"
                               placeholder="Tìm theo tên, email...">
                    </div>
                </div>
            </form>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4">Nhân viên</th>
                            <th>Vai trò</th>
                            <th>Trạng thái</th>
                            <th class="text-center" style="width:250px">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-sm me-3">A</div>
                                    <div>
                                        <div class="fw-bold">Nguyễn Văn A</div>
                                        <small class="text-muted">a@gmail.com</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <i class="fa-solid fa-user-shield me-1 text-secondary"></i> Admin
                            </td>
                            <td>
                                <span class="badge bg-success-subtle text-success badge-status border border-success">
                                    ● Đang làm
                                </span>
                            </td>
                            <td class="text-center">
                                <a href="/Employee/Edit/1" class="btn btn-action btn-outline-warning" title="Chỉnh sửa">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                <a href="/Employee/ChangePassword/1" class="btn btn-action btn-outline-info" title="Đổi mật khẩu">
                                    <i class="fa-solid fa-key"></i>
                                </a>
                                <a href="/Employee/ChangeRole/1" class="btn btn-action btn-outline-secondary" title="Phân quyền">
                                    <i class="fa-solid fa-shield-halved"></i>
                                </a>
                                <a href="/Employee/Delete/1"
                                   onclick="return confirm('Xóa nhân viên này?')"
                                   class="btn btn-action btn-outline-danger" title="Xóa">
                                    <i class="fa-solid fa-trash-can"></i>
                                </a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
